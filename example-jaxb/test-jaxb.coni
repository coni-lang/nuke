(require "libs/java/src/maven.coni" :as maven)
(let [repos ["https://repo1.maven.org/maven2"]
      deps ["org.glassfish.jaxb:jaxb-xjc:4.0.5"
            "org.glassfish.jaxb:jaxb-core:4.0.5"
            "org.glassfish.jaxb:codemodel:4.0.5"
            "org.glassfish.jaxb:xsom:4.0.5"
            "org.glassfish.jaxb:txw2:4.0.5"
            "com.sun.istack:istack-commons-tools:4.1.2"
            "com.sun.istack:istack-commons-runtime:4.1.2"
            "com.sun.xml.dtd-parser:dtd-parser:1.5.1"
            "com.sun.xml.bind.external:rngom:4.0.5"
            "com.sun.xml.bind.external:relaxng-datatype:4.0.5"]]
  (println (maven/resolve-deps deps repos)))
